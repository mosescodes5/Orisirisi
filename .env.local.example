# Copy this file to .env.local for local dev, and add the same keys in
# Vercel → Project → Settings → Environment Variables for production.

# --- Payments (Paystack) ---
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=
# Server-only — used to verify transactions in /api/verify-payment.
PAYSTACK_SECRET_KEY=

# --- Email: Resend (primary) ---
# Create an API key at resend.com/api-keys. RESEND_FROM_EMAIL must be on a
# domain you've verified in Resend (Domains → Add Domain) — until then,
# Resend will only deliver to your own account's email address.
RESEND_API_KEY=
RESEND_FROM_EMAIL="Orísirísi with Taiwo <hello@orisirisiwithtaiwo.com>"

# --- Email: Gmail SMTP (automatic fallback if Resend fails or isn't set) ---
# Requires 2-Step Verification on the Google account, then an App Password
# from myaccount.google.com/apppasswords — your normal Gmail password will
# NOT work here.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
STORE_NAME="Orísirísi with Taiwo"
STORE_URL=https://orisirisiwithtaiwo.com
# Where order/subscriber/contact notifications are sent (defaults to SMTP_USER)
ADMIN_EMAIL=

# --- Database (Supabase) — products, orders, admin auth ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Blog CMS (Sanity) ---
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Only required if your dataset is private, or you want to preview drafts.
SANITY_API_READ_TOKEN=
