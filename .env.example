# Paystack public key (test or live). Get this from your Paystack dashboard
# under Settings > API Keys & Webhooks. Only the PUBLIC key belongs here —
# never put the secret key in a NEXT_PUBLIC_ variable.
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Server-only — used by /api/verify-payment to confirm transactions actually
# succeeded before recording an order as paid. Never expose with NEXT_PUBLIC_.
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase (products, orders, auth)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
# Server-only — never expose with NEXT_PUBLIC_. Used for payment verification,
# admin writes, etc. from API routes only.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Sanity (blog CMS)
NEXT_PUBLIC_SANITY_PROJECT_ID=your-project-id
NEXT_PUBLIC_SANITY_DATASET=production
SANITY_API_READ_TOKEN=your-read-token
