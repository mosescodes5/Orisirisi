# Copy this file to .env.local for local dev, and add the same keys in
# Vercel → Project → Settings → Environment Variables for production.

# --- Payments (Paystack) ---
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# --- Email: Brevo (primary) ---
# Create an API key at app.brevo.com -> Settings -> SMTP & API -> API Keys
# (use a "transactional" API key). BREVO_FROM_EMAIL must be a "Sender"
# you've verified in Brevo (Settings -> Senders & IP) — a Gmail address you
# own works fine as a verified sender, no business domain required.
BREVO_API_KEY=
BREVO_FROM_EMAIL="Orísirísi with Taiwo <yourname@gmail.com>"

# --- Email: Gmail SMTP (automatic fallback if Brevo fails or isn't set) ---
# Requires 2-Step Verification on the Google account, then an App Password
# from myaccount.google.com/apppasswords — your normal Gmail password will
# NOT work here.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=

STORE_NAME="Orísirísi with Taiwo"
STORE_URL=https://orisirisiwithtaiwo.com
# Where order/subscriber/contact notifications are sent (defaults to SMTP_USER)
ADMIN_EMAIL=

# --- Database (Supabase) — added once we wire up products/orders/auth ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- Sanity (blog CMS) — not wired up yet, blog still reads from src/lib/data.ts ---
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# NEXT_PUBLIC_SANITY_DATASET=production
# SANITY_API_READ_TOKEN=
